# =============================================================================
# 本地开发环境变量（仅用于本地 npm run dev 开发）
# =============================================================================
# 注意：
#  1. 本地开发时，使用主账号密钥直接上传 OSS（跳过 STS）
#  2. 生产环境会自动使用 STS 临时凭证，更安全
#  3. VITE_ 前缀使变量在浏览器中可访问
#  4. 切勿提交真实密钥到 Git（.env 已在 .gitignore 中）

# 阿里云 AccessKey（本地开发直传 OSS）
# 获取地址: https://ram.console.aliyun.com/manage/ak
VITE_ALIYUN_ACCESS_KEY_ID=your_access_key_id
VITE_ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 阿里云 OSS Bucket 配置（本地开发）
# Region 列表: https://help.aliyun.com/document_detail/31837.html
VITE_ALIYUN_OSS_REGION=oss-cn-hangzhou
VITE_ALIYUN_OSS_BUCKET=your-bucket-name

# =============================================================================
# 后端环境变量（必须在 Vercel 项目设置中配置）
# =============================================================================
# 配置路径：Vercel 项目 → Settings → Environment Variables
# 说明：这些变量用于服务器端 STS 临时凭证生成，必须配置

# 阿里云 AccessKey（用于调用 STS API）
# 获取地址: https://ram.console.aliyun.com/manage/ak
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 阿里云 RAM 角色 ARN（用于生成 STS 临时凭证）
# 创建角色: https://ram.console.aliyun.com/roles
# 格式: acs:ram::账号ID:role/角色名称
ALIYUN_ROLE_ARN=acs:ram::your-account-id:role/your-role-name

# 阿里云 OSS Bucket 配置
# Region 列表: https://help.aliyun.com/document_detail/31837.html
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=your-bucket-name

# =============================================================================
# v0.2.2 新增：Supabase 配置（账号体系 - 必须配置）
# =============================================================================
# 获取地址: https://supabase.com/dashboard/project/_/settings/api
# 说明：用于用户认证和数据存储，必须在部署前配置

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# AI 模型 API Key（可选 - 用于开发测试）
# =============================================================================
# 说明：这些 Key 可在页面设置中配置，也可在此配置用于本地开发测试
# 阿里百炼: https://dashscope.console.aliyun.com/apiKey
# 火山方舟: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey

# 阿里百炼 API Key（可选）
VITE_DASHSCOPE_API_KEY=your_dashscope_api_key

# 火山引擎 ARK API Key（可选）
VITE_ARK_API_KEY=your_ark_api_key
